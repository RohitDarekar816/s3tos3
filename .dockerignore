data/
logs/

# Test artifacts
tests/
coverage/
*.test.js

# Dev tooling
ecosystem.config.cjs
.kiro/

# Version control
.git/
.gitignore
.gitattributes

# Docs
README*
*.md

# OS noise
.DS_Store
Thumbs.db
*.log
