# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Logging ───────────────────────────────────────────────────────────────
# Controls log verbosity. Options: debug | info | warn | error
# debug → all messages including HTTP requests and internal state changes
# info  → normal operational messages (default)
# warn  → warnings and errors only
# error → errors only
LOG_LEVEL=info

# ── HTTP Basic Authentication ─────────────────────────────────────────────
# Set both to enable. Leave blank to disable (only safe on private networks).
AUTH_USER=admin
AUTH_PASSWORD=change-this-to-a-strong-random-password

# ── CORS (WebSocket) ───────────────────────────────────────────────────────
# Set to your public domain when deploying behind a reverse proxy.
# ALLOWED_ORIGIN=https://backup.yourdomain.com

# ── AWS / S3 defaults (optional) ──────────────────────────────────────────
# Fallback credentials for reading/deleting backup artifacts from S3.
# Per-job credentials in the UI always take precedence.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
